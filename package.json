    "test": "tsx --test src/service.test.ts"
  },
  "dependencies": {
    "express": "^5.0.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^20.19.27",
    "tsx": "^4.20.5",
    "typescript": "^5.6.3"
  }
}
