{
  "name": "@maitrix/memory-core",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Standalone memory core service for multi-app AI context and profile memory",
  "engines": {
    "node": ">=18"
  },
  "main": "dist/index.js",
  "scripts": {
